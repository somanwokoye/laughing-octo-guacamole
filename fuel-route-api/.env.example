# Copy this file to .env and fill in the values:  cp .env.example .env

# Django secret key — generate your own (e.g. `python -c "import secrets; print(secrets.token_urlsafe(50))"`)
SECRET_KEY=replace-with-your-own-secret-key

DEBUG=True

# Outbound TLS verification for the OSRM / Nominatim / Census / GeoNames calls.
# Keep True in normal environments. Set to False ONLY when running behind a
# TLS-inspecting corporate proxy (e.g. Zscaler) whose re-signing CA is rejected
# by OpenSSL 3.x — otherwise leave it secure.
EXTERNAL_SSL_VERIFY=True
